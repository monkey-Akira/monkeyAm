{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "lib": ["esnext", "dom"]
    },
    "include": [
        "**/*.js",
        "types/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build"
    ]
}
